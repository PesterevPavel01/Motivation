{
    "ConnectionStrings": {
        "AppDbConnectionString": "Host=localhost;Port=5432;Database=motivation_identity;Username=admin;Password=admin;Include Error Detail=true",
        "Redis": "localhost:6379,password=RedisCatalog1234!,abortConnect=false,connectTimeout=30000,syncTimeout=30000"
    },
    "AuthServer": {
        "Url": "https://localhost:10001",
        "IssuerUri": "https://localhost:10001",
        "Clients": {
            "MachineToMachine": {
                "ClientId": "service-to-service",
                "ClientSecret": "secret-service-to-service-auth"
            },
            "SyncMachineToMachine": {
                "ClientId": "sync-service-to-service",
                "ClientSecret": "secret-sync-service-to-service-auth",
                "ClientRoles": [
                    "Administrator"
                ]
            },
            "UserToService": {
                "ClientId": "user-to-service",
                "ClientSecret": "secret-user-to-service-auth"
            }
        },
        "DevCertificates": true
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "OpenIddict": "Warning"
            }
        },
        "WriteTo": [
            { "Name": "Console" },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/log-.log",
                    "rollingInterval": "Day",
                    "rollOnFileSizeLimit": true,
                    "shared": true,
                    "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
    }
}
